# Copy this file to .env.local and fill in your values

# Google Calendar OAuth2 — get from https://console.cloud.google.com/
# Create a project → Enable "Google Calendar API" → Create OAuth2 credentials
# Add authorized redirect URI: http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Public app URL (used in OAuth redirect URI)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-32-plus-random-chars

# Encryption key for Google tokens at rest (32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-hex-chars

# Default admin password (used only on first run to seed the hash; change in admin afterwards)
INITIAL_ADMIN_PASSWORD=familie
